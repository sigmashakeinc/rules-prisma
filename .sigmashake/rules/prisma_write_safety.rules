# prisma_write_safety.rules
# Technology: prisma | Capability: write

rule prisma-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "$executeRawUnsafe"
  MESSAGE "Blocked an unsafe pattern in prisma. Use the recommended best practices for 2025/2026."
}

rule prisma-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "prisma.raw"
  MESSAGE "You are using an outdated API for prisma. Please upgrade to the newer API."
}
